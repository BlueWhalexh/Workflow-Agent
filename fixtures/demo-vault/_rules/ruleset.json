{
  "schemaVersion": 1,
  "rulesetId": "demo-vault-mvp-phase0",
  "workspaceKind": "obsidian-compatible-markdown-vault",
  "writableRoots": ["Inbox/", "Projects/"],
  "readableRoots": ["Inbox/", "Projects/"],
  "protectedRoots": ["_rules/", "_golden/"],
  "frontmatterSchema": {
    "type": "object",
    "required": ["title", "project", "type", "date", "status", "source"],
    "properties": {
      "title": { "type": "string", "minLength": 1 },
      "project": {
        "type": "string",
        "enum": ["Atlas Search", "Beacon Ops", "Cobalt Notes", "Delta Research"]
      },
      "type": {
        "type": "string",
        "enum": ["meeting", "research", "moc"]
      },
      "date": {
        "type": "string",
        "pattern": "^20[0-9]{2}-[0-9]{2}-[0-9]{2}$"
      },
      "status": {
        "type": "string",
        "enum": ["inbox", "active", "archived"]
      },
      "source": {
        "type": "string",
        "enum": ["user-note", "clipped-research", "design-reading", "seed"]
      }
    },
    "additionalProperties": true
  },
  "linkPolicy": {
    "allowWikiLinks": true,
    "allowMarkdownLinks": true,
    "requireResolvableInternalLinks": true
  },
  "sourceAttribution": {
    "requiredForUpdate": true,
    "rangeRequired": true
  },
  "maxOperationsPerChangeset": 24,
  "maxBytesPerChangeset": 120000,
  "approvalExpiryMinutes": 15,
  "trashPolicy": {
    "allowed": false
  }
}
